<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <app.simple.felicity.decorations.views.AspectRatioPreviewCardView
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="@dimen/padding_15"
        android:layout_weight="1" />

    <app.simple.felicity.decorations.ripple.DynamicRippleLinearLayout
        android:id="@+id/selection_item_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_margin="@dimen/padding_15"
        android:padding="@dimen/padding_15">

        <app.simple.felicity.decorations.toggles.CheckBox
            android:id="@+id/selection_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical" />

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:id="@+id/selection_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_14"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/padding_5"
            app:appFontStyle="bold"
            app:textColorStyle="primary" />

    </app.simple.felicity.decorations.ripple.DynamicRippleLinearLayout>

</LinearLayout>
