<?xml version="1.0" encoding="utf-8"?>
<app.simple.felicity.decorations.padding.PaddingAwareLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    app:navigationPaddingRequired="true"
    app:statusPaddingRequired="false">

    <!--
        The header sits at the very top and stays put while the content below scrolls.
        A classic combo — like peanut butter and jelly.
    -->
    <app.simple.felicity.decorations.views.AppHeader
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:headerContentLayout="@layout/header_preferences_generic" />

    <!--
        Everything between the header and the buy button lives inside this scroll view,
        so it all stays reachable even on smaller screens.
    -->
    <app.simple.felicity.decorations.padding.PaddingAwareNestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:navigationPaddingRequired="false"
        app:statusPaddingRequired="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp">

            <!-- Trial status section — lets the user know how much free time is left. -->
            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:id="@+id/section_trial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/trial"
                android:textSize="@dimen/text_size_12"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                app:appFontStyle="bold"
                app:textColorStyle="accent" />

            <!--
                Shows the actual trial countdown — or a polite note that time's up.
                Populated at runtime from TrialPreferences.
            -->
            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:id="@+id/trial_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="24dp"
                android:textSize="@dimen/text_size_16"
                app:appFontStyle="medium"
                app:textColorStyle="secondary" />

            <!-- What's in the box — a friendly rundown of what the full version unlocks. -->
            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:id="@+id/section_features"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/purchase"
                android:textSize="@dimen/text_size_12"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                app:appFontStyle="bold"
                app:textColorStyle="accent" />

            <!-- Feature bullet list — because everyone loves knowing what they're paying for. -->

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/all_features_summary"
                android:textSize="@dimen/text_size_14"
                android:gravity="center_vertical"
                android:drawablePadding="@dimen/padding_5"
                app:appFontStyle="medium"
                app:drawableStartCompat="@drawable/ic_dot_12dp"
                app:drawableTintStyle="accent"
                app:textColorStyle="secondary" />

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/feature_unlimited_playback"
                android:textSize="@dimen/text_size_14"
                android:gravity="center_vertical"
                android:drawablePadding="@dimen/padding_5"
                app:appFontStyle="medium"
                app:drawableStartCompat="@drawable/ic_dot_12dp"
                app:drawableTintStyle="accent"
                app:textColorStyle="secondary" />

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/feature_equalizer"
                android:textSize="@dimen/text_size_14"
                android:gravity="center_vertical"
                android:drawablePadding="@dimen/padding_5"
                app:appFontStyle="medium"
                app:drawableStartCompat="@drawable/ic_dot_12dp"
                app:drawableTintStyle="accent"
                app:textColorStyle="secondary" />

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/feature_milkdrop"
                android:textSize="@dimen/text_size_14"
                android:gravity="center_vertical"
                android:drawablePadding="@dimen/padding_5"
                app:appFontStyle="medium"
                app:drawableStartCompat="@drawable/ic_dot_12dp"
                app:drawableTintStyle="accent"
                app:textColorStyle="secondary" />

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/feature_themes"
                android:textSize="@dimen/text_size_14"
                android:gravity="center_vertical"
                android:drawablePadding="@dimen/padding_5"
                app:appFontStyle="medium"
                app:drawableStartCompat="@drawable/ic_dot_12dp"
                app:drawableTintStyle="accent"
                app:textColorStyle="secondary" />

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/feature_lyrics"
                android:textSize="@dimen/text_size_14"
                android:gravity="center_vertical"
                android:drawablePadding="@dimen/padding_5"
                app:appFontStyle="medium"
                app:drawableStartCompat="@drawable/ic_dot_12dp"
                app:drawableTintStyle="accent"
                app:textColorStyle="secondary" />

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/feature_wifi_server"
                android:textSize="@dimen/text_size_14"
                android:gravity="center_vertical"
                android:drawablePadding="@dimen/padding_5"
                app:appFontStyle="medium"
                app:drawableStartCompat="@drawable/ic_dot_12dp"
                app:drawableTintStyle="accent"
                app:textColorStyle="secondary" />

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/feature_no_subscription"
                android:textSize="@dimen/text_size_14"
                android:gravity="center_vertical"
                android:drawablePadding="@dimen/padding_5"
                app:appFontStyle="medium"
                app:drawableStartCompat="@drawable/ic_dot_12dp"
                app:drawableTintStyle="accent"
                app:textColorStyle="secondary" />

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/feature_updates"
                android:textSize="@dimen/text_size_14"
                android:gravity="center_vertical"
                android:drawablePadding="@dimen/padding_5"
                app:appFontStyle="medium"
                app:drawableStartCompat="@drawable/ic_dot_12dp"
                app:drawableTintStyle="accent"
                app:textColorStyle="secondary" />

        </LinearLayout>

    </app.simple.felicity.decorations.padding.PaddingAwareNestedScrollView>

    <!--
        The big buy button always stays at the bottom — no scrolling required to find it.
        When billing is loading, it's dimmed and disabled so nothing weird happens.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_20">

        <!--
            Price display row — only visible when an offer is active.
            Shows the original price struck through (greyed out) right next to
            the discounted offer price, so the user can see at a glance how much
            they're saving. Hidden by default; shown from code when a deal exists.
        -->
        <LinearLayout
            android:id="@+id/price_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:layout_marginBottom="10dp"
            android:layout_marginHorizontal="@dimen/padding_20"
            android:orientation="horizontal"
            android:visibility="gone">

            <!-- The regular full price — crossed out and greyed to make the deal unmissable. -->
            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:id="@+id/original_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:textSize="@dimen/text_size_14"
                app:appFontStyle="regular"
                app:textColorStyle="tertiary" />

            <!-- The offer price badge — an accent pill showing what the user actually pays. -->
            <app.simple.felicity.decorations.highlight.HighlightTextView
                android:id="@+id/offer_price_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="@dimen/text_size_14"
                android:textStyle="bold"
                app:highlightMode="both"
                app:useAccentColor="true" />

        </LinearLayout>

        <app.simple.felicity.decorations.highlight.HighlightTextView
            android:id="@+id/buy_button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:gravity="center"
            android:textSize="@dimen/text_size_18"
            android:textStyle="bold"
            android:text="@string/purchase_now"
            app:highlightMode="both" />

    </LinearLayout>

</app.simple.felicity.decorations.padding.PaddingAwareLinearLayout>

