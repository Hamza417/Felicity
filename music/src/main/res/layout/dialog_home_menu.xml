<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_gravity="bottom"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="@dimen/padding_15"
    android:layout_height="wrap_content">

    <app.simple.felicity.decorations.corners.DynamicCornerLinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:padding="@dimen/padding_15"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:orientation="horizontal">

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="0dp"
                android:padding="@dimen/padding_15"
                android:layout_height="wrap_content"
                android:text="@string/grid_type"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:textSize="@dimen/text_size_14"
                app:appFontStyle="bold"
                app:textColorStyle="primary" />

            <app.simple.felicity.decorations.ripple.DynamicRippleImageButton
                android:id="@+id/reset"
                android:layout_width="@dimen/button_size"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="@dimen/padding_10"
                android:src="@drawable/ic_reset"
                app:buttonTintType="regular" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/grid_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                app:selectionRequired="true"
                app:singleSelection="true">

                <app.simple.felicity.decorations.toggles.Button
                    android:id="@+id/grid"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="@dimen/button_size"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_grid_16dp"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:minHeight="0dp"
                    app:minWidth="0dp" />

                <app.simple.felicity.decorations.toggles.Button
                    android:id="@+id/list"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="@dimen/button_size"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_list_16dp"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:minHeight="0dp"
                    app:minWidth="0dp" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </LinearLayout>

        <app.simple.felicity.decorations.theme.ThemeDivider
            android:layout_width="match_parent"
            android:layout_marginVertical="@dimen/padding_10"
            android:layout_height="1px" />

        <app.simple.felicity.decorations.ripple.DynamicRippleTextView
            android:id="@+id/open_app_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="@dimen/padding_15"
            android:text="@string/open_app_settings"
            android:textSize="@dimen/text_size_14"
            app:appFontStyle="bold"
            app:textColorStyle="primary" />

    </app.simple.felicity.decorations.corners.DynamicCornerLinearLayout>

</FrameLayout>

