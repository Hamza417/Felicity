<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_gravity="bottom"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="@dimen/padding_15"
    android:layout_height="wrap_content">

    <app.simple.felicity.decorations.corners.DynamicCornerLinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:padding="@dimen/padding_15"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_height="wrap_content">

                <app.simple.felicity.decorations.typeface.TypeFaceTextView
                    android:layout_width="match_parent"
                    android:paddingHorizontal="@dimen/padding_15"
                    android:paddingTop="@dimen/padding_15"
                    android:layout_height="wrap_content"
                    android:text="@string/stack_media_controls"
                    android:layout_gravity="center_vertical"
                    android:textSize="@dimen/text_size_14"
                    app:appFontStyle="bold"
                    app:textColorStyle="primary" />

                <app.simple.felicity.decorations.typeface.TypeFaceTextView
                    android:layout_width="match_parent"
                    android:paddingHorizontal="@dimen/padding_15"
                    android:paddingBottom="@dimen/padding_15"
                    android:layout_height="wrap_content"
                    android:text="@string/stack_media_controls_summary"
                    android:layout_gravity="center_vertical"
                    android:textSize="@dimen/text_size_12"
                    app:appFontStyle="regular"
                    app:textColorStyle="tertiary" />

            </LinearLayout>

            <app.simple.felicity.decorations.toggles.FelicitySwitch
                android:id="@+id/stack_media_controls_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:orientation="horizontal">

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="0dp"
                android:padding="@dimen/padding_15"
                android:layout_height="wrap_content"
                android:text="@string/timer_position"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:textSize="@dimen/text_size_14"
                app:appFontStyle="bold"
                app:textColorStyle="primary" />

            <app.simple.felicity.decorations.toggles.FelicityButtonGroup
                android:id="@+id/timer_gravity_button_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical" />

        </LinearLayout>

    </app.simple.felicity.decorations.corners.DynamicCornerLinearLayout>

</FrameLayout>

