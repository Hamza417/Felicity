<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <app.simple.felicity.milkdrop.views.MilkdropSurfaceView
        android:id="@+id/milkdrop_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <app.simple.felicity.decorations.ripple.DynamicRippleTextView
        android:id="@+id/presets"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="@dimen/padding_15"
        android:layout_margin="@dimen/padding_25"
        android:text="@string/presets"
        app:appFontStyle="bold"
        app:textColorStyle="white" />

</FrameLayout>

