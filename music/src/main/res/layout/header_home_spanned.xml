<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:animateLayoutChanges="true"
    android:orientation="vertical">

    <!-- Main row: app label + action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/padding_15">

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:id="@+id/label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:maxLines="1"
            android:singleLine="true"
            android:text="@string/app_name"
            android:textSize="@dimen/text_size_36"
            app:appFontStyle="black"
            app:textColorStyle="primary" />

        <app.simple.felicity.decorations.ripple.DynamicRippleImageButton
            android:id="@+id/search"
            android:layout_width="@dimen/button_size"
            android:layout_height="@dimen/button_size"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_search" />

        <app.simple.felicity.decorations.ripple.DynamicRippleImageButton
            android:id="@+id/server_toggle"
            android:layout_width="@dimen/button_size"
            android:layout_height="@dimen/button_size"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_wifi" />

        <app.simple.felicity.decorations.ripple.DynamicRippleImageButton
            android:id="@+id/settings"
            android:layout_width="@dimen/button_size"
            android:layout_height="@dimen/button_size"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_settings" />

    </LinearLayout>

    <!-- Chip strip: library stats + server-active indicator -->
    <HorizontalScrollView
        android:id="@+id/strip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_5"
        android:animateLayoutChanges="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fadingEdge="horizontal"
        android:fadingEdgeLength="@dimen/padding_20"
        android:paddingHorizontal="@dimen/padding_15"
        android:requiresFadingEdge="horizontal"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Track count chip -->
            <app.simple.felicity.decorations.highlight.HighlightTextView
                android:id="@+id/library_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="@dimen/padding_5"
                android:drawableStart="@drawable/ic_pie_16dp"
                android:ellipsize="marquee"
                android:gravity="center_vertical"
                android:marqueeRepeatLimit="marquee_forever"
                android:maxLines="1"
                android:maxWidth="250dp"
                android:paddingHorizontal="@dimen/padding_10"
                android:paddingVertical="@dimen/padding_5"
                android:singleLine="true"
                android:textSize="@dimen/text_size_14"
                android:visibility="gone"
                app:appFontStyle="bold"
                app:drawableTintStyle="accent"
                app:highlightMode="outline"
                app:textColorStyle="secondary" />

            <!-- Only visible while the Wi-Fi server is running -->
            <app.simple.felicity.decorations.highlight.HighlightTextView
                android:id="@+id/server_active_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_8"
                android:drawablePadding="@dimen/padding_5"
                android:drawableStart="@drawable/ic_wifi_16dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/padding_10"
                android:paddingVertical="@dimen/padding_5"
                android:singleLine="true"
                android:text="@string/server_active"
                android:textSize="@dimen/text_size_14"
                android:visibility="gone"
                app:appFontStyle="bold"
                app:drawableTintStyle="accent"
                app:highlightMode="outline"
                app:textColorStyle="secondary" />

        </LinearLayout>

    </HorizontalScrollView>

    <app.simple.felicity.decorations.theme.ThemeDivider
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginTop="@dimen/padding_10" />

</LinearLayout>

