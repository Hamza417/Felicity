<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/padding_15">

    <app.simple.felicity.decorations.corners.DynamicCornerLinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/padding_15"
        android:orientation="vertical">

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:drawablePadding="@dimen/padding_5"
            android:gravity="center_vertical"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:text="@string/app_name_full"
            android:textSize="@dimen/text_size_12"
            android:layout_gravity="center_vertical"
            app:appFontStyle="bold"
            app:drawableStartCompat="@drawable/ic_felicity_full_16dp"
            app:drawableTintStyle="accent"
            app:textColorStyle="accent" />

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:id="@+id/warning"
            android:drawablePadding="@dimen/padding_5"
            android:gravity="center_vertical"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:layout_marginTop="@dimen/padding_10"
            android:text="@string/app_name_full"
            android:textSize="@dimen/text_size_14"
            app:appFontStyle="bold"
            app:textColorStyle="primary" />


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_marginTop="@dimen/padding_10"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:orientation="horizontal">

            <app.simple.felicity.decorations.ripple.DynamicRippleTextView
                android:id="@+id/close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="@dimen/padding_15"
                android:layout_gravity="end"
                android:text="@string/close"
                app:appFontStyle="bold"
                app:textColorStyle="accent" />

        </LinearLayout>

    </app.simple.felicity.decorations.corners.DynamicCornerLinearLayout>

</FrameLayout>