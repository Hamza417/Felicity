<?xml version="1.0" encoding="utf-8"?>
<app.simple.felicity.decorations.padding.PaddingAwareNestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/padding_20">

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:maxLines="1"
                android:singleLine="true"
                android:text="@string/app_name"
                android:textSize="@dimen/text_size_48"
                app:appFontStyle="black"
                app:textColorStyle="primary" />

            <app.simple.felicity.decorations.ripple.DynamicRippleImageButton
                android:id="@+id/search"
                android:layout_width="@dimen/button_size"
                android:layout_height="@dimen/button_size"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_search" />

            <app.simple.felicity.decorations.ripple.DynamicRippleImageButton
                android:id="@+id/menu"
                android:layout_width="@dimen/button_size"
                android:layout_height="@dimen/button_size"
                android:layout_gravity="center_vertical"
                android:src="@drawable/ic_settings" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/recently_played_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/padding_8"
                android:paddingHorizontal="@dimen/padding_20"
                android:paddingTop="@dimen/padding_20"
                android:text="@string/recently_played"
                android:textSize="@dimen/text_size_22"
                app:appFontStyle="bold"
                app:textColorStyle="primary" />

            <app.simple.felicity.decorations.overscroll.CustomHorizontalRecyclerView
                android:id="@+id/recently_played_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/padding_20"
                app:navigationPaddingRequired="false"
                app:statusPaddingRequired="false" />

        </LinearLayout>

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/padding_8"
            android:paddingHorizontal="@dimen/padding_20"
            android:paddingTop="@dimen/padding_20"
            android:text="@string/browse"
            android:textSize="@dimen/text_size_22"
            app:appFontStyle="bold"
            app:textColorStyle="primary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/panels_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never" />

        <LinearLayout
            android:id="@+id/recently_added_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/padding_8"
                android:paddingHorizontal="@dimen/padding_20"
                android:paddingTop="@dimen/padding_20"
                android:text="@string/recently_added"
                android:textSize="@dimen/text_size_22"
                app:appFontStyle="bold"
                app:textColorStyle="primary" />

            <app.simple.felicity.decorations.overscroll.CustomHorizontalRecyclerView
                android:id="@+id/recently_added_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/padding_20"
                app:navigationPaddingRequired="false"
                app:statusPaddingRequired="false" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/favorites_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="@dimen/padding_8"
                android:paddingHorizontal="@dimen/padding_20"
                android:paddingTop="@dimen/padding_20"
                android:text="@string/favorites"
                android:textSize="@dimen/text_size_22"
                app:appFontStyle="bold"
                app:textColorStyle="primary" />

            <app.simple.felicity.decorations.overscroll.CustomHorizontalRecyclerView
                android:id="@+id/favorites_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/padding_20"
                app:navigationPaddingRequired="false"
                app:statusPaddingRequired="false" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/mini_player_height" />

    </LinearLayout>

</app.simple.felicity.decorations.padding.PaddingAwareNestedScrollView>
