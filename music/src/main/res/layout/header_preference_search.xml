<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:animateLayoutChanges="true"
    android:orientation="vertical"
    tools:ignore="RtlSymmetry">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:animateLayoutChanges="true"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/padding_15">

        <app.simple.felicity.decorations.corners.DynamicCornerEditText
            android:id="@+id/edit_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/padding_1"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:gravity="center_vertical"
            android:hint="@string/search"
            android:imeOptions="actionSearch"
            android:importantForAutofill="yes"
            android:inputType="text"
            android:maxLines="1"
            android:padding="@dimen/padding_10"
            app:appFontStyle="bold"
            app:textColorStyle="primary" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:animateLayoutChanges="true"
        android:layout_marginTop="@dimen/padding_5"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/padding_15">

        <app.simple.felicity.decorations.highlight.HighlightTextView
            android:id="@+id/count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:drawablePadding="@dimen/padding_5"
            android:drawableStart="@drawable/ic_search"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/padding_10"
            android:paddingVertical="@dimen/padding_5"
            android:textSize="@dimen/text_size_14"
            app:appFontStyle="bold"
            app:drawableTintStyle="accent"
            app:textColorStyle="tertiary"
            tools:text="12 Results" />

    </LinearLayout>

    <app.simple.felicity.decorations.theme.ThemeDivider
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginTop="@dimen/padding_10" />

</LinearLayout>

