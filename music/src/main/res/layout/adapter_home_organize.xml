<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/padding_5"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/padding_10"
    android:paddingVertical="@dimen/padding_8">

    <app.simple.felicity.decorations.theme.ThemeIcon
        android:id="@+id/icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center_vertical"
        app:tintType="accent" />

    <app.simple.felicity.decorations.typeface.TypeFaceTextView
        android:id="@+id/title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="@dimen/padding_12"
        android:layout_weight="1"
        android:textSize="@dimen/text_size_14"
        app:appFontStyle="bold"
        app:textColorStyle="secondary" />

    <app.simple.felicity.decorations.theme.ThemeIcon
        android:id="@+id/drag_handle"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="@dimen/padding_8"
        android:src="@drawable/ic_drag_indicator"
        app:tintType="regular" />

</LinearLayout>

