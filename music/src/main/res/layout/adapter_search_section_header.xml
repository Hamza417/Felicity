<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <app.simple.felicity.decorations.typeface.TypeFaceTextView
        android:id="@+id/section_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/padding_15"
        android:paddingVertical="@dimen/padding_5"
        android:textSize="@dimen/text_size_18"
        app:appFontStyle="black"
        app:textColorStyle="accent" />

    <app.simple.felicity.decorations.theme.ThemeDivider
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:layout_height="1px" />

</LinearLayout>

