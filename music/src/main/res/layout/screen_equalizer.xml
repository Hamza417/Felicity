<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <app.simple.felicity.decorations.seekbars.FelicityEqualizerSliders
        android:id="@+id/equalizer_sliders"
        android:layout_width="match_parent"
        android:paddingHorizontal="@dimen/padding_15"
        android:layout_weight="1"
        android:layout_height="0dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/padding_20"
        android:paddingVertical="@dimen/padding_15"
        android:orientation="horizontal">

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:textSize="@dimen/text_size_16"
            android:text="@string/apply_equalizer"
            app:appFontStyle="bold"
            app:textColorStyle="primary" />

        <app.simple.felicity.decorations.highlight.HighlightTextView
            android:id="@+id/presets_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/padding_5"
            android:padding="@dimen/padding_10"
            android:text="@string/presets"
            app:appFontStyle="bold"
            app:textColorStyle="secondary" />

        <app.simple.felicity.decorations.highlight.HighlightTextView
            android:id="@+id/reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="@dimen/padding_5"
            android:padding="@dimen/padding_10"
            android:layout_marginEnd="@dimen/padding_15"
            android:text="@string/reset"
            app:appFontStyle="bold"
            app:textColorStyle="secondary" />

        <app.simple.felicity.decorations.toggles.FelicitySwitch
            android:id="@+id/equalizer_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical" />

    </LinearLayout>

    <app.simple.felicity.decorations.theme.ThemeDivider
        android:layout_width="match_parent"
        android:layout_marginHorizontal="@dimen/padding_20"
        android:layout_marginVertical="@dimen/padding_10"
        android:layout_height="1px" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/padding_15">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/eq_mid_guideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5" />

        <app.simple.felicity.decorations.knobs.RotaryKnobView
            android:id="@+id/bass_knob"
            android:layout_width="@dimen/balance_knob_dimension"
            android:layout_height="@dimen/balance_knob_dimension"
            app:layout_constraintEnd_toStartOf="@+id/eq_mid_guideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_12"
            android:text="@string/bass"
            android:gravity="center"
            android:ellipsize="marquee"
            android:layout_marginTop="@dimen/padding_10"
            android:maxLines="1"
            android:singleLine="true"
            android:marqueeRepeatLimit="marquee_forever"
            app:appFontStyle="regular"
            app:layout_constraintEnd_toStartOf="@+id/eq_mid_guideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/bass_knob"
            app:textColorStyle="heading" />

        <app.simple.felicity.decorations.knobs.RotaryKnobView
            android:id="@+id/treble_knob"
            android:layout_width="@dimen/balance_knob_dimension"
            android:layout_height="@dimen/balance_knob_dimension"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/eq_mid_guideline"
            app:layout_constraintTop_toTopOf="parent" />

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_12"
            android:gravity="center"
            android:ellipsize="marquee"
            android:layout_marginTop="@dimen/padding_10"
            android:maxLines="1"
            android:singleLine="true"
            android:marqueeRepeatLimit="marquee_forever"
            android:text="@string/treble"
            app:appFontStyle="regular"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/eq_mid_guideline"
            app:layout_constraintTop_toBottomOf="@+id/treble_knob"
            app:textColorStyle="heading" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>