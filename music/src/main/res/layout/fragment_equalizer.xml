<?xml version="1.0" encoding="utf-8"?>
<app.simple.felicity.decorations.theme.ThemeCoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <app.simple.felicity.decorations.padding.PaddingAwareNestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior=".decorations.behaviors.OverScrollBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/padding_10"
                android:orientation="horizontal">

                <app.simple.felicity.decorations.typeface.TypeFaceTextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_size_48"
                    android:text="@string/equalizer"
                    app:appFontStyle="black"
                    app:textColorStyle="primary" />

                <app.simple.felicity.decorations.ripple.DynamicRippleImageButton
                    android:id="@+id/search"
                    android:layout_gravity="center_vertical"
                    android:layout_width="@dimen/button_size"
                    android:src="@drawable/ic_search"
                    android:layout_height="@dimen/button_size" />

                <app.simple.felicity.decorations.ripple.DynamicRippleImageButton
                    android:id="@+id/menu"
                    android:layout_gravity="center_vertical"
                    android:layout_width="@dimen/button_size"
                    android:src="@drawable/ic_settings"
                    android:layout_height="@dimen/button_size" />

            </LinearLayout>

            <app.simple.felicity.decorations.theme.ThemeDivider
                android:layout_width="match_parent"
                android:layout_height="1px" />

            <LinearLayout
                android:layout_marginTop="@dimen/padding_10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/padding_20"
                android:orientation="horizontal">

                <app.simple.felicity.decorations.typeface.TypeFaceTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="@dimen/text_size_16"
                    android:layout_gravity="center_vertical"
                    android:text="@string/karaoke_mode" />

                <app.simple.felicity.decorations.toggles.FelicitySwitch
                    android:id="@+id/karaoke_mode_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/padding_20"
                android:orientation="horizontal">

                <app.simple.felicity.decorations.typeface.TypeFaceTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="@dimen/text_size_16"
                    android:layout_gravity="center_vertical"
                    android:text="@string/night_mode" />

                <app.simple.felicity.decorations.toggles.FelicitySwitch
                    android:id="@+id/night_mode_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical" />

            </LinearLayout>

            <app.simple.felicity.decorations.theme.ThemeDivider
                android:layout_width="match_parent"
                android:layout_marginHorizontal="@dimen/padding_20"
                android:layout_marginVertical="@dimen/padding_10"
                android:layout_height="1px" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <app.simple.felicity.decorations.knobs.RotaryKnobView
                        android:id="@+id/balanceKnob"
                        android:layout_width="@dimen/balance_knob_dimension"
                        android:layout_height="@dimen/balance_knob_dimension"
                        android:layout_gravity="center" />

                    <app.simple.felicity.decorations.typeface.TypeFaceTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_12"
                        android:text="@string/balance"
                        android:gravity="center"
                        android:ellipsize="marquee"
                        android:layout_marginTop="@dimen/padding_10"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:layout_gravity="center_vertical"
                        app:appFontStyle="regular"
                        app:textColorStyle="heading" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <app.simple.felicity.decorations.knobs.RotaryKnobView
                        android:id="@+id/stereo_widening_knob"
                        android:layout_width="@dimen/balance_knob_dimension"
                        android:layout_height="@dimen/balance_knob_dimension"
                        android:layout_gravity="center" />

                    <app.simple.felicity.decorations.typeface.TypeFaceTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_size_12"
                        android:gravity="center"
                        android:ellipsize="marquee"
                        android:layout_marginTop="@dimen/padding_10"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:text="@string/stereo_widening"
                        android:layout_gravity="center_vertical"
                        app:appFontStyle="regular"
                        app:textColorStyle="heading" />

                </LinearLayout>

            </LinearLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="@dimen/padding_10" />

            <app.simple.felicity.decorations.knobs.RotaryKnobView
                android:id="@+id/tape_saturation_knob"
                android:layout_width="@dimen/balance_knob_dimension"
                android:layout_height="@dimen/balance_knob_dimension"
                android:layout_gravity="center" />

            <app.simple.felicity.decorations.typeface.TypeFaceTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_12"
                android:text="@string/tape_saturation"
                android:gravity="center"
                android:ellipsize="marquee"
                android:maxLines="1"
                android:singleLine="true"
                android:marqueeRepeatLimit="marquee_forever"
                android:layout_gravity="center_vertical"
                android:layout_marginTop="@dimen/padding_10"
                app:appFontStyle="regular"
                app:textColorStyle="heading" />

        </LinearLayout>

    </app.simple.felicity.decorations.padding.PaddingAwareNestedScrollView>

</app.simple.felicity.decorations.theme.ThemeCoordinatorLayout>
