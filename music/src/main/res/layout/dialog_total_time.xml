<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/padding_15">

    <app.simple.felicity.decorations.corners.DynamicCornerLinearLayout xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/dialog_padding">

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:id="@+id/text"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:textSize="@dimen/text_size_14"
            app:appFontStyle="medium"
            app:textColorStyle="primary" />

        <LinearLayout
            android:animateLayoutChanges="true"
            android:layout_gravity="end"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dialog_padding"
            android:layout_width="wrap_content"
            android:orientation="horizontal">

            <app.simple.felicity.decorations.ripple.DynamicRippleTextView
                android:id="@+id/sure"
                android:gravity="center"
                android:layout_gravity="end|center_vertical"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:padding="@dimen/padding_15"
                android:text="@string/ok"
                android:textSize="@dimen/text_size_14"
                app:appFontStyle="bold"
                app:textColorStyle="accent" />

        </LinearLayout>

    </app.simple.felicity.decorations.corners.DynamicCornerLinearLayout>
</FrameLayout>
