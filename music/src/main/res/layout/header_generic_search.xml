<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:animateLayoutChanges="true"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    tools:ignore="RtlSymmetry">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/padding_15"
        android:animateLayoutChanges="true"
        android:orientation="horizontal">

        <app.simple.felicity.decorations.corners.DynamicCornerEditText
            android:id="@+id/edit_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="@dimen/padding_10"
            android:background="@android:color/transparent"
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="@dimen/padding_1"
            android:hint="@string/search"
            android:imeOptions="actionSearch"
            android:importantForAutofill="yes"
            android:inputType="text"
            android:maxLines="1"
            app:appFontStyle="bold"
            app:textColorStyle="primary" />

        <app.simple.felicity.decorations.views.Loader
            android:id="@+id/progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_5"
            android:layout_gravity="center"
            android:visibility="gone" />

        <app.simple.felicity.decorations.ripple.DynamicRippleImageButton
            android:id="@+id/search"
            android:layout_gravity="center_vertical"
            android:layout_width="@dimen/button_size"
            android:src="@drawable/ic_search"
            android:layout_height="@dimen/button_size" />


    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:animateLayoutChanges="true"
        android:layout_marginTop="@dimen/padding_5"
        android:paddingHorizontal="@dimen/padding_15"
        android:orientation="horizontal">

        <app.simple.felicity.decorations.highlight.HighlightTextView
            android:id="@+id/count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingVertical="@dimen/padding_5"
            android:paddingHorizontal="@dimen/padding_10"
            android:drawableStart="@drawable/ic_lyrics_16dp"
            android:drawablePadding="@dimen/padding_5"
            android:textSize="@dimen/text_size_14"
            android:layout_gravity="center_vertical"
            app:appFontStyle="bold"
            app:drawableTintStyle="accent"
            app:textColorStyle="tertiary" />

    </LinearLayout>


    <app.simple.felicity.decorations.theme.ThemeDivider
        android:layout_width="match_parent"
        android:layout_marginTop="@dimen/padding_10"
        android:layout_height="1px" />

</LinearLayout>