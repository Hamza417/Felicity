<?xml version="1.0" encoding="utf-8"?>
<app.simple.felicity.decorations.ripple.DynamicRippleLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <app.simple.felicity.decorations.square.SquareFrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <app.simple.felicity.decorations.theme.ThemeIcon
            android:id="@+id/album_art"
            android:layout_width="match_parent"
            android:src="@drawable/ic_folder"
            android:layout_height="match_parent"
            app:tintType="accent"
            tools:ignore="ContentDescription" />

    </app.simple.felicity.decorations.square.SquareFrameLayout>

    <app.simple.felicity.decorations.typeface.TypeFaceTextView
        android:id="@+id/name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textSize="@dimen/text_size_16"
        app:appFontStyle="bold"
        app:textColorStyle="primary" />

    <app.simple.felicity.decorations.typeface.TypeFaceTextView
        android:id="@+id/song_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textSize="@dimen/desc_text_size"
        app:appFontStyle="regular"
        app:textColorStyle="accent" />

</app.simple.felicity.decorations.ripple.DynamicRippleLinearLayout>

