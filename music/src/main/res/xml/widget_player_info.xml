<?xml version="1.0" encoding="utf-8"?><!--
    1×4 widget — one launcher row tall, four columns wide.
    updatePeriodMillis=0 means Android will never wake us up on a timer;
    every redraw is triggered manually from the service or a user tap.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/widget_name"
    android:initialLayout="@layout/widget_player"
    android:minWidth="294dp"
    android:minHeight="50dp"
    android:resizeMode="horizontal"
    android:targetCellWidth="4"
    android:targetCellHeight="1"
    android:updatePeriodMillis="0"
    android:widgetCategory="home_screen" />
