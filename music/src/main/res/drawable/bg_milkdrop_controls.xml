<?xml version="1.0" encoding="utf-8"?><!--
    Rounded semi-transparent black background used for the controls overlay panel
    on the Milkdrop visualizer screen.  The fill is 60 % opaque black so the
    projectM waveform remains subtly visible behind the controls while still
    providing enough contrast for white text and icon tints.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#99000000" />

    <corners android:radius="20dp" />

</shape>

