<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <app.simple.felicity.decorations.knobs.RotaryKnobView
            android:id="@+id/reverb_mix_knob"
            android:layout_width="@dimen/balance_knob_dimension"
            android:layout_height="@dimen/balance_knob_dimension"
            android:layout_gravity="center" />

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_12"
            android:text="@string/reverb_mix"
            android:gravity="center"
            android:ellipsize="marquee"
            android:layout_marginTop="@dimen/padding_10"
            android:maxLines="1"
            android:singleLine="true"
            android:marqueeRepeatLimit="marquee_forever"
            android:layout_gravity="center_vertical"
            app:appFontStyle="regular"
            app:textColorStyle="heading" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <app.simple.felicity.decorations.knobs.RotaryKnobView
            android:id="@+id/reverb_fade_knob"
            android:layout_width="@dimen/balance_knob_dimension"
            android:layout_height="@dimen/balance_knob_dimension"
            android:layout_gravity="center" />

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_12"
            android:text="@string/reverb_fade"
            android:gravity="center"
            android:ellipsize="marquee"
            android:layout_marginTop="@dimen/padding_10"
            android:maxLines="1"
            android:singleLine="true"
            android:marqueeRepeatLimit="marquee_forever"
            android:layout_gravity="center_vertical"
            app:appFontStyle="regular"
            app:textColorStyle="heading" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <app.simple.felicity.decorations.knobs.RotaryKnobView
            android:id="@+id/reverb_damp_knob"
            android:layout_width="@dimen/balance_knob_dimension"
            android:layout_height="@dimen/balance_knob_dimension"
            android:layout_gravity="center" />

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_12"
            android:text="@string/reverb_damp"
            android:gravity="center"
            android:ellipsize="marquee"
            android:layout_marginTop="@dimen/padding_10"
            android:maxLines="1"
            android:singleLine="true"
            android:marqueeRepeatLimit="marquee_forever"
            android:layout_gravity="center_vertical"
            app:appFontStyle="regular"
            app:textColorStyle="heading" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <app.simple.felicity.decorations.knobs.RotaryKnobView
            android:id="@+id/reverb_size_knob"
            android:layout_width="@dimen/balance_knob_dimension"
            android:layout_height="@dimen/balance_knob_dimension"
            android:layout_gravity="center" />

        <app.simple.felicity.decorations.typeface.TypeFaceTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_size_12"
            android:text="@string/reverb_size"
            android:gravity="center"
            android:ellipsize="marquee"
            android:layout_marginTop="@dimen/padding_10"
            android:maxLines="1"
            android:singleLine="true"
            android:marqueeRepeatLimit="marquee_forever"
            android:layout_gravity="center_vertical"
            app:appFontStyle="regular"
            app:textColorStyle="heading" />

    </LinearLayout>

</LinearLayout>
